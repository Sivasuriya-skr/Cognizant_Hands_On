<configuration>
    <!-- Console appender outputs messages to standard out -->
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <!-- Logging pattern format: Date, Thread name, Log level (padded to 5 chars), Logger name, Message -->
            <pattern>%d{yyyy-MM-dd HH:mm:ss} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Root level logger set to debug, directing all logging events to console -->
    <root level="debug">
        <appender-ref ref="STDOUT" />
    </root>
</configuration>
